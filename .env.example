# Required
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=
ANTHROPIC_API_KEY=

# Database (default matches docker-compose)
DATABASE_URL=postgresql+asyncpg://bratbot:bratbot@localhost:5432/bratbot

# Redis (default matches docker-compose)
REDIS_URL=redis://localhost:6379/0

# Optional
LOG_LEVEL=DEBUG
# GUILD_ID=123456789012345678  # Set for instant slash command sync in dev

# Rate Limiting (defaults shown)
# RATE_LIMIT_USER_SECONDS=5
# RATE_LIMIT_CHANNEL_PER_MINUTE=10

# LLM Queue (defaults shown)
# LLM_QUEUE_MAX_DEPTH=5
# LLM_TIMEOUT_SECONDS=30
