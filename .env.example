# Local Development Environment Variables
# Copy this file to .env and fill in the required values
# See README.md for setup instructions

# ============================================
# REQUIRED - Discord Bot Configuration
# ============================================

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Your Discord application ID
DISCORD_CLIENT_ID=your-client-id-here

# Your Discord public key (Ed25519) for interaction signature verification
# Get this from your application's General Information page
DISCORD_PUBLIC_KEY=your-public-key-here

# ============================================
# REQUIRED - LLM API Configuration
# ============================================

# Base URL for the BratBotModel API (local development uses localhost)
# In Docker Compose, this is the internal URL within the container
LLM_API_URL=http://localhost:8000

# ============================================
# REQUIRED - Redis Configuration
# ============================================

# Redis connection string for rate limiting and caching
# Default matches docker-compose setup
REDIS_URL=redis://localhost:6379/0

# ============================================
# OPTIONAL - Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
# DEBUG: Colored console output (good for local development)
# INFO: Production level logging
# Default: INFO
LOG_LEVEL=DEBUG

# ============================================
# OPTIONAL - Discord Bot Configuration
# ============================================

# Guild ID for faster slash command sync during development
# If set, slash commands sync only to this guild (instant)
# If not set, commands sync globally (can take up to 1 hour)
# Recommended: Set during development, remove for production
# GUILD_ID=123456789012345678

# ============================================
# OPTIONAL - Rate Limiting Configuration
# ============================================

# Per-user cooldown in seconds (prevents spam from individual users)
# Default: 5
# RATE_LIMIT_USER_SECONDS=5

# Maximum LLM responses per channel per minute
# Default: 10
# RATE_LIMIT_CHANNEL_PER_MINUTE=10

# ============================================
# OPTIONAL - LLM Behavior Configuration
# ============================================

# Default brat level (1-3)
# 1: Mildly tedious
# 2: Dry sarcasm
# 3: Maximum brat (default)
# Default: 3
# LLM_BRAT_LEVEL=3

# ============================================
# OPTIONAL - Ollama Configuration
# ============================================

# Ollama API base URL (used by the model API internally)
# In Docker Compose, this is the internal service URL
# Default: http://ollama:11434
# OLLAMA_BASE_URL=http://ollama:11434

# Ollama model name to load
# Can be any model from Ollama's registry or a custom model
# Default: qwen3-14b
# OLLAMA_MODEL=qwen3-14b

# Local path to GGUF model files (mounted into Ollama at /models)
# Only needed if using custom GGUF files instead of Ollama registry
# Example: /path/to/your/models
# LLM_MODELS_DIR=/path/to/your/models

# ============================================
# OPTIONAL - Request Queue Configuration
# ============================================

# Maximum queued LLM requests per channel
# Prevents memory bloat from too many pending requests
# Default: 5
# LLM_QUEUE_MAX_DEPTH=5

# LLM request timeout in seconds
# How long to wait for a response from Ollama before failing
# Default: 30
# LLM_TIMEOUT_SECONDS=30
