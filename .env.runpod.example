# ─── RunPod Deployment Configuration ─────────────────────────────────
# Copy this file to .env.runpod and fill in your values.
# Used by: scripts/deploy-runpod.sh

# RunPod pod ID (from RunPod console, e.g. "abc123xyz")
RUNPOD_POD_ID=

# Docker registry image (push target)
REGISTRY_IMAGE=ghcr.io/your-org/bratbot

# Image tag
IMAGE_TAG=runpod-latest

# SSH key for connecting to the pod
RUNPOD_SSH_KEY=~/.ssh/id_ed25519

# ─── Pod Environment Variables ───────────────────────────────────────
# These are set in the RunPod pod template, NOT read by the script.
# Listed here for reference.
#
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_CLIENT_ID=your-client-id
# DISCORD_PUBLIC_KEY=your-public-key
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b
# LLM_API_URL=http://localhost:8000
# DATABASE_URL=postgresql+asyncpg://bratbot:xxx@ep-xxx.neon.tech/bratbot?sslmode=require
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
