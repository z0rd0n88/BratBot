# ─── Stage 1: Build BratBot (Discord bot) ─────────────────────────────
FROM python:3.12-slim AS bot-builder

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock* README.md ./
RUN uv export --format requirements-txt --no-dev --no-hashes --no-emit-project > requirements.txt && \
    pip install --no-cache-dir --prefix=/install -r requirements.txt

# ─── Stage 2: Build BratBotModel (FastAPI personality API) ────────────
FROM python:3.12-slim AS model-builder

WORKDIR /model
COPY model/requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ─── Stage 3: Runtime — all services via supervisord ──────────────────
FROM python:3.12-slim AS runtime

# Tell NVIDIA container toolkit to expose GPU devices and driver libs.
# Without these, the toolkit won't map /dev/nvidia* even if the host has GPUs.
# Ollama bundles its own CUDA runtime, so we don't need a CUDA base image.
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

RUN apt-get update && apt-get install -y --no-install-recommends \
    supervisor curl ca-certificates zstd \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Copy installed packages — model first, then bot (bot's lockfile takes precedence)
COPY --from=model-builder /install /usr/local
COPY --from=bot-builder /install /usr/local

# BratBot files — editable install so hot-update can sync source without rebuilding
WORKDIR /app
COPY pyproject.toml README.md /app/
COPY src/ /app/src/
RUN pip install --no-cache-dir --no-deps -e /app

# BratBotModel files
COPY model/ /model/

# Supervisor config
COPY supervisord.runpod.conf /etc/supervisor/conf.d/supervisord.conf

# Entrypoint
COPY scripts/runpod-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8000

CMD ["/entrypoint.sh"]
