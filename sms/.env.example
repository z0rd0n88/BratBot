# SMS Gateway Environment Variables
# Copy this file to sms/.env and fill in the required values

# ============================================
# REQUIRED - Twilio Configuration
# ============================================

# Your Twilio Account SID (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token (from console.twilio.com)
TWILIO_AUTH_TOKEN=your-auth-token-here

# Your Twilio phone number in E.164 format
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# REQUIRED - Service URLs
# ============================================

# Base URL of the BratBotModel API (personality/LLM layer)
# In Docker Compose, model runs on localhost:8000 in the same container
LLM_API_URL=http://localhost:8000

# Redis connection string (shared with Discord bot for rate limiting)
REDIS_URL=redis://redis:6379/0

# ============================================
# OPTIONAL - Behavior Configuration
# ============================================

# Default brat level for SMS responses (1-3, default: 3)
# LLM_BRAT_LEVEL=3

# LLM request timeout in seconds (default: 30)
# LLM_TIMEOUT_SECONDS=30

# Per-user SMS cooldown in seconds (default: 5)
# RATE_LIMIT_USER_SECONDS=5

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# ============================================
# OPTIONAL - Development / Testing
# ============================================

# Set to true to skip Twilio webhook signature validation
# ONLY use this for local development/testing — never in production
# TWILIO_SKIP_VALIDATION=false

# ============================================
# SETUP - Twilio Webhook Configuration
# ============================================
# In the Twilio console, go to:
#   Phone Numbers → Manage → Active Numbers → your number → Messaging
# Set the webhook URL (HTTP POST) to:
#   https://your-server.com:8001/incoming
